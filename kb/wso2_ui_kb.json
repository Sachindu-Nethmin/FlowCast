{
  "_description": "WSO2 Integrator UI knowledge base — extracted from product-integrator source code. Maps field labels to their OCR-visible text, placeholders, and form context.",

  "fields": {
    "Integration Name": {
      "placeholder": null,
      "component": "TextField",
      "form": "bi_creation",
      "required": true,
      "auto_focus": true,
      "search_hints": ["Integration Name", "integration name"],
      "notes": "First field in BI creation form, auto-focused"
    },
    "Package Name": {
      "placeholder": null,
      "component": "TextField",
      "form": "bi_creation",
      "required": false,
      "search_hints": ["Package Name", "package name"],
      "notes": "Auto-populated from Integration Name. Only type here if overriding."
    },
    "Select Path": {
      "placeholder": "Enter path or browse to select a folder...",
      "component": "DirectorySelector",
      "form": "bi_creation",
      "required": true,
      "search_hints": ["Select Path", "Enter path or browse to select a folder", "Browse"],
      "notes": "Has a Browse button next to it. Click Browse to open native folder picker."
    },
    "Workspace Name": {
      "placeholder": "Enter workspace name",
      "component": "TextField",
      "form": "bi_creation",
      "required": false,
      "search_hints": ["Workspace Name", "Enter workspace name"],
      "notes": "Only visible when 'Create as workspace' checkbox is checked"
    },
    "Organization Name": {
      "placeholder": null,
      "component": "TextField",
      "form": "bi_creation",
      "required": false,
      "search_hints": ["Organization Name", "organization name"],
      "notes": "Under optional Package Information section"
    },
    "Package Version": {
      "placeholder": "0.1.0",
      "component": "TextField",
      "form": "bi_creation",
      "required": false,
      "search_hints": ["Package Version", "0.1.0"],
      "notes": "Default value shown as placeholder: 0.1.0"
    },
    "Service base path": {
      "placeholder": null,
      "default_value": "/",
      "component": "TextField",
      "form": "http_service",
      "required": true,
      "search_hints": ["Service base path", "base path", "/"],
      "notes": "Text field for HTTP service base path. Pre-filled with '/' by default."
    },
    "Listener port": {
      "placeholder": null,
      "default_value": "9090",
      "component": "TextField",
      "form": "http_service",
      "required": true,
      "search_hints": ["Listener port", "port", "9090"],
      "notes": "Numeric text field for HTTP listener port. Pre-filled with 9090."
    },
    "Service contract": {
      "placeholder": null,
      "component": "Dropdown",
      "form": "http_service",
      "required": true,
      "options": ["Design from scratch"],
      "search_hints": ["Service contract", "Design from scratch"],
      "notes": "Dropdown selector. 'Design from scratch' is default option."
    },
    "MI Integration Name": {
      "placeholder": null,
      "component": "TextField",
      "form": "mi_creation",
      "required": true,
      "search_hints": ["Integration Name", "integration name"],
      "notes": "MI project creation form first field"
    },
    "MI Runtime Version": {
      "placeholder": null,
      "component": "Dropdown",
      "form": "mi_creation",
      "required": true,
      "search_hints": ["WSO2 Integrator", "MI runtime version"],
      "notes": "Dropdown for MI runtime version selection"
    },
    "Select Integration Path": {
      "placeholder": null,
      "component": "LocationSelector",
      "form": "mi_creation",
      "required": true,
      "search_hints": ["Select Integration Path", "Browse"],
      "notes": "Directory picker for MI project location"
    },
    "Group Id": {
      "placeholder": null,
      "component": "TextField",
      "form": "mi_creation",
      "required": false,
      "default_value": "com.microintegrator.projects",
      "search_hints": ["Group Id", "com.microintegrator.projects"],
      "notes": "Under Advanced Options. Default: com.microintegrator.projects"
    },
    "Artifact Id": {
      "placeholder": null,
      "component": "TextField",
      "form": "mi_creation",
      "required": false,
      "search_hints": ["Artifact Id", "artifact id"],
      "notes": "Under Advanced Options. Auto-synced with Integration Name."
    },
    "Version": {
      "placeholder": null,
      "component": "TextField",
      "form": "mi_creation",
      "required": false,
      "default_value": "1.0.0",
      "search_hints": ["Version", "1.0.0"],
      "notes": "Under Advanced Options. Default: 1.0.0"
    }
  },

